# Research API host (the trimmed server). Local dev default: http://localhost:3000
VITE_API_URL=http://localhost:3000

# Firebase web app config (same Firebase project the server verifies against).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MEASUREMENT_ID=

# Google Identity Services OAuth client id (for the sign-in button).
VITE_GOOGLE_OAUTH_CLIENT_ID=
