# ── port.py ─────────────────────────────────────────────────────────────────
# Source: where the full PMT dataset lives (your machine — never shared).
SOURCE_MONGO_URI=mongodb://localhost:27017
SOURCE_DB_NAME=pmt_data

# Target: the dedicated research Atlas cluster.
TARGET_MONGO_URI=
TARGET_DB_NAME=pmt_research

# ── merge_verdicts.py (end of project) ──────────────────────────────────────
# Verdict source (usually the same as TARGET_MONGO_URI).
RESEARCH_MONGO_URI=
RESEARCH_DB_NAME=pmt_research
# Main audit store — point at your main tooling's AUDIT_MONGO_URI target.
MAIN_AUDIT_MONGO_URI=
MAIN_AUDIT_DB_NAME=pmt_data
