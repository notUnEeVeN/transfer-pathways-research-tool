{
  "_meta": {
    "purpose": "Hand-gathered FULL four-year BSCS/EECS graduation requirements per UC campus, modeled in the ASSIST agreement requirement_groups shape so the degree-coverage figure (MA Fig. 1) can reuse the existing choose-N eligibility engine. Course codes are resolved to university_courses.parent_id by scripts/import_uc_degree_requirements.py; provenance for every datum lives in docs/figures/degree-coverage-sources.md.",
    "authoring_schema": {
      "campus_key -> object": {
        "school_id": "UC source id (matches assist_institutions.source_id and assist_agreements.uc_school_id)",
        "school": "display name",
        "program": "the exact degree program these requirements describe",
        "total_units": "minimum units for graduation (secondary; the engine counts course-slots)",
        "source_url": "primary catalog URL for the program (details per-datum in the source-of-truth doc)",
        "groups[]": {
          "title": "human label",
          "tier": "transferable | breadth | nontransferable",
          "requirements[]": {
            "select": "N — the choose-N count (section_advisement)",
            "from": "one of: [course codes] (explicit courses, resolved to parent_id) | {series: [[codes...], ...]} (choose `select` complete series — 'in its entirety, no mixing'; a series articulates only when every course in it does) | {departments:[...], max_number:N} (proxy list: all lower-div courses in these depts) | null (non-transferable slots — never satisfiable by any CC)",
            "units": "optional — the block's stated total units (e.g. Berkeley's 20-unit UD rule, a 12-unit series), stored as unit_advisement; the page's unit-budget check otherwise assumes a flat ~4u/course"
          }
        }
      }
    },
    "notes": [
      "tier=transferable: real lower-division courses a CC can articulate (has a parent_id).",
      "tier=breadth: H/SS / natural-science that transfers near-universally via breadth articulation; modeled as select-N from a department proxy list (v1). Refinement TODO: split R&C (2) from breadth (4).",
      "tier=nontransferable: upper-division / residency / free electives — no CC equivalent by construction (ASSIST never articulates UC upper-division). Rendered as kind='requirement' receivers with no parent_id, so they always count against the denominator and are never satisfiable.",
      "EECS<->ELENG alias: our scraped data still stores EECS 16A/16B; the current Berkeley catalog calls these ELENG 66/64. The importer aliases them, so codes may be authored either way."
    ]
  },
