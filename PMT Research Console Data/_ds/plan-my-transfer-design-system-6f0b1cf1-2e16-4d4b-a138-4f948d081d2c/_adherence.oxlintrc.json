{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/Button/**",
              "components/buttons/IconButton/**",
              "components/display/Badge/**",
              "components/display/CompletionCheck/**",
              "components/display/Divider/**",
              "components/display/Frame/**",
              "components/display/IconBadge/**",
              "components/display/Logo/**",
              "components/display/NavList/**",
              "components/display/OptionCard/**",
              "components/display/Reveal/**",
              "components/display/StatStrip/**",
              "components/display/Tabs/**",
              "components/feedback/Alert/**",
              "components/feedback/BulkActionBar/**",
              "components/feedback/EmptyState/**",
              "components/feedback/LoadingLogo/**",
              "components/feedback/LoadingPage/**",
              "components/feedback/ProgressRing/**",
              "components/feedback/Skeleton/**",
              "components/feedback/Spinner/**",
              "components/feedback/UndoToast/**",
              "components/forms/Checkbox/**",
              "components/forms/Combobox/**",
              "components/forms/Input/**",
              "components/forms/MonthPicker/**",
              "components/forms/Select/**",
              "components/forms/Switch/**",
              "components/forms/Textarea/**",
              "components/general/CatalogLoading/**",
              "components/general/HBarList/**",
              "components/general/KeyValuePanel/**",
              "components/general/MiniBarChart/**",
              "components/general/ProgressLoader/**",
              "components/general/ProportionBar/**",
              "components/general/Tooltip/**",
              "components/general/UserInitialsAvatar/**",
              "components/layout/CommandBar/**",
              "components/layout/MarketingSection/**",
              "components/layout/PageContainer/**",
              "components/layout/Panel/**",
              "components/layout/Stack/**",
              "components/overlays/FullScreenPanel/**",
              "components/overlays/Modal/**",
              "components/overlays/MoveToPopover/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|message|children|className|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: type, message, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:success|error|info)$/]",
        "message": "<Alert> type must be one of 'success' | 'error' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|wrap|children|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, icon, wrap, children, className."
