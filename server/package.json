{
  "name": "pmt-research-server",
  "version": "0.1.0",
  "private": true,
  "description": "Research console API: read routes over the curated research dataset + the audit stack",
  "main": "server.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:local": "MONGO_URI=mongodb://localhost:27017 DB_NAME=pmt_research nodemon server.js",
    "schema:audit": "node scripts/migrateCanonicalSchema.js",
    "schema:apply": "node scripts/migrateCanonicalSchema.js --apply",
    "schema:cleanup": "node scripts/migrateCanonicalSchema.js --apply --drop-legacy --yes",
    "slots:audit": "node scripts/migrateAsDegreeSlots.js",
    "slots:apply": "node scripts/migrateAsDegreeSlots.js --apply",
    "snapshot:multi-campus": "node scripts/generateMultiCampusPathwaysSnapshot.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^12.5.0",
    "mongodb": "^6.8.0"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.1.4",
    "vitest": "^2.0.5"
  }
}
