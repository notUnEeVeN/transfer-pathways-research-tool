# ── Mongo (research cluster) ────────────────────────────────────────────────
# The reference handle. Points at the DEDICATED research Atlas cluster (or a
# local Mongo in dev). This repo must never be configured with the production
# cluster URI.
MONGO_URI=mongodb://localhost:27017
# Optional second handle for team working state. Leave unset to keep the
# compact schema in one database (the normal research deployment).
# AUDIT_MONGO_URI=
DB_NAME=pmt_research

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
# Comma-separated deployed frontend origins (localhost is auto-allowed in dev).
# ALLOWED_ORIGINS=https://research.example.com

# Optional: enables structured AI proposals in the AS-degree validation editor.
# The manual editor remains fully available when this is unset.
ANTHROPIC_API_KEY=

# ── Access control ──────────────────────────────────────────────────────────
# Comma-separated Firebase UIDs with the ADMIN role (dataset visibility +
# partner access management). Partners are granted in-app by an admin and
# live in the team_members collection — no env change needed for them.
ADMIN_UIDS=

# ── Firebase Admin (token verification) ─────────────────────────────────────
# Service-account fields, same names as the production server's env.
TYPE=service_account
PROJECT_ID=
PRIVATE_KEY_ID=
PRIVATE_KEY=
CLIENT_EMAIL=
CLIENT_ID=
AUTH_URI=https://accounts.google.com/o/oauth2/auth
TOKEN_URI=https://oauth2.googleapis.com/token
AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
CLIENT_X509_CERT_URL=
UNIVERSE_DOMAIN=googleapis.com
